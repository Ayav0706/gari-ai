# ============================================
# GARI – Plantilla de Configuración
# ============================================
# Copia este archivo como .env y rellena tus credenciales.

TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""
# Optional for production webhook mode:
# TELEGRAM_WEBHOOK_URL="https://your-service.onrender.com/telegram/webhook"
# TELEGRAM_WEBHOOK_SECRET="set-a-random-secret"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
KIMI_API_KEY=""
CRITIC_PASS_ENABLED="true"
DB_PATH="./data/memory.db"
AGENT_REQUEST_TIMEOUT_MS="90000"
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
# For cloud deployments (Render, etc): paste full JSON service account here
# FIREBASE_CREDENTIALS='{"type":"service_account",...}'
ELEVENLABS_API_KEY=""
